---
import site from '../data/site.json';
import Logo from './Logo.astro';
const year = new Date().getFullYear();
const links = [
  { href: '/people', label: 'People' },
  { href: '/publications', label: 'Publications' },
  { href: '/resources', label: 'Resources' },
  { href: '/news', label: 'News' },
];
---
<footer class="bg-navy-dark text-white/75">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 sm:grid-cols-2 md:grid-cols-[1.5fr_1fr_1fr]">
    <div>
      <Logo class="h-8 w-auto" light />
      <p class="mt-4 max-w-sm text-sm leading-relaxed">{site.tagline}</p>
    </div>
    <div>
      <div class="text-xs font-bold uppercase tracking-wider text-white/50">Explore</div>
      <ul class="mt-4 space-y-2 text-sm">
        {links.map((l) => <li><a href={l.href} class="hover:text-red">{l.label}</a></li>)}
      </ul>
    </div>
    <div>
      <div class="text-xs font-bold uppercase tracking-wider text-white/50">Connect</div>
      <ul class="mt-4 space-y-2 text-sm">
        {site.social.github && <li><a href={site.social.github} class="hover:text-red">GitHub</a></li>}
        {site.social.scholar && <li><a href={site.social.scholar} class="hover:text-red">Scholar</a></li>}
        {site.social.twitter && <li><a href={site.social.twitter} class="hover:text-red">Twitter</a></li>}
        {site.contact && <li><a href={`mailto:${site.contact}`} class="hover:text-red">Contact</a></li>}
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10 py-4 text-center text-xs text-white/45">
    © {year} DreamAI. Built with Astro · Hosted on GitHub Pages.
  </div>
</footer>
