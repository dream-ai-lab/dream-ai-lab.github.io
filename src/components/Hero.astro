---
import site from '../data/site.json';
const { heading, subheading, primaryCta, secondaryCta, image } = site.hero;
const bg = image ?? '/images/hero.jpg';
---
<section class="relative isolate overflow-hidden bg-navy-dark text-white">
  <!-- background image + overlay -->
  <div class="absolute inset-0 -z-10">
    <img src={bg} alt="" class="h-full w-full object-cover opacity-70" />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-dark via-navy-dark/85 to-navy-dark/30"></div>
  </div>

  <div class="mx-auto max-w-6xl px-5 py-24 md:py-32">
    <div class="max-w-2xl">
      <div class="reveal text-sm font-bold uppercase tracking-[0.2em] text-white/70">DreamAI Research Group</div>
      <h1 class="reveal mt-5 font-sans text-4xl font-extrabold uppercase leading-[1.05] tracking-tight md:text-6xl">{heading}</h1>
      <div class="reveal mt-5 h-1 w-20 bg-cyan"></div>
      <p class="reveal mt-6 max-w-xl text-lg leading-relaxed text-white/85">{subheading}</p>
      <div class="reveal mt-9 flex flex-wrap gap-3">
        <a href={primaryCta.href} class="rounded-sm bg-red px-7 py-3.5 text-sm font-bold uppercase tracking-wide text-white transition-colors hover:bg-red-dark">{primaryCta.label}</a>
        <a href={secondaryCta.href} class="rounded-sm border border-white/40 px-7 py-3.5 text-sm font-bold uppercase tracking-wide text-white transition-colors hover:bg-white/10">{secondaryCta.label}</a>
      </div>
    </div>
  </div>
</section>
