---
// DreamAI wordmark — user-provided vector logo (background removed, cropped).
// "DREAM" uses currentColor (navy on light, white on dark); "AI" keeps its cyan.
import logo from '../assets/dreamai-logo.svg?raw';
interface Props {
  class?: string;
  light?: boolean;
}
const { class: className, light = false } = Astro.props;
const ink = light ? '#FFFFFF' : '#0E2438';
---
<span class:list={['inline-flex', className]} style={`color:${ink}`} set:html={logo} />
