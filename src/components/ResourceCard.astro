---
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';
interface Props {
  resource: CollectionEntry<'resources'>['data'];
}
const { resource } = Astro.props;
---
<a href={resource.url} target="_blank" rel="noopener" class="group flex h-full flex-col rounded-md border border-slate-200 bg-white p-6 transition hover:-translate-y-1 hover:shadow-lg">
  <h3 class="flex items-center gap-1.5 font-sans text-base font-bold text-navy">
    {resource.name}
    <Icon name="lucide:arrow-up-right" class="h-3.5 w-3.5 text-red" aria-hidden="true" />
  </h3>
  <p class="mt-2 flex-1 text-sm text-ink/75">{resource.description}</p>
  {resource.tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {resource.tags.map((t) => <span class="rounded-sm bg-mist px-2 py-0.5 text-xs font-medium text-navy">{t}</span>)}
    </div>
  )}
</a>
